---
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mares Popa</title>
    <GoogleAnalytics measurementId={"G-WY0KQ8W98H"} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    
    <script is:inline>
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>

  <body class="bg-[#f8f8f8] dark:bg-[#1a1a1a] text-[#111] dark:text-[#eee] font-mono selection:bg-[#007aff]/20 transition-colors duration-500 antialiased">
    
    <div class="max-w-[640px] mx-auto px-8 py-20 md:py-40">
      
      <header class="flex justify-between items-baseline mb-32">
        <a href="/" class="text-sm font-bold tracking-tight hover:text-[#007aff] transition-colors">Mares Popa</a>
        <ThemeToggle />
      </header>

      <main class="space-y-24">

        <section>
          <p class="text-[22px] md:text-[26px] leading-[1.4] font-medium tracking-tight">
            Senior software engineer. <br />
            <span class="text-[#888] dark:text-[#666]">Building privacy-first tools</span> <br />
            <span class="text-[#888] dark:text-[#666]">and writing about the web.</span>
          </p>
        </section>

        <section class="space-y-8">
          <h2 class="text-xs font-bold text-[#007aff] uppercase tracking-widest">Writing</h2>
          <div class="space-y-6">
            {posts.map(post => (
              <a href={`/blog/${post.id}`} class="group block no-underline">
                <div class="flex flex-col md:flex-row md:justify-between md:items-baseline gap-2">
                  <span class="text-[16px] group-hover:text-[#007aff] transition-colors underline decoration-transparent group-hover:decoration-[#007aff]/30 underline-offset-4">
                    {post.data.title}
                  </span>
                  <span class="text-[13px] text-[#aaa] dark:text-[#444] shrink-0">
                    {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
                  </span>
                </div>
              </a>
            ))}
          </div>
          <a href="/blog" class="inline-block text-[13px] text-[#888] hover:text-[#007aff] transition-colors">
            Index →
          </a>
        </section>

        <section class="space-y-8">
          <h2 class="text-xs font-bold text-[#007aff] uppercase tracking-widest">Projects</h2>
          <ul class="space-y-10">
            <li>
              <a href="https://github.com/marespopa/hermes" class="group">
                <span class="text-[16px] group-hover:text-[#007aff] transition-colors">Hermes Markdown</span>
                <p class="text-[#888] text-[14px] mt-2 leading-[1.6]">Privacy first, local first markdown editor.</p>
              </a>
            </li>
            <li>
              <a href="https://github.com/marespopa/dolooper" class="group">
                <span class="text-[16px] group-hover:text-[#007aff] transition-colors">Dolooper</span>
                <p class="text-[#888] text-[14px] mt-2 leading-[1.6]">Draft, plan execute your tasks with full privacy.</p>
              </a>
            </li>
          </ul>
        </section>

        <section class="space-y-8 border-t border-[#eee] dark:border-[#222] pt-12">
          <div class="flex gap-x-8 text-[13px]">
            <a href="mailto:hello@marespopa.com" class="text-[#888] hover:text-[#007aff] transition-colors">Email</a>
            <a href="https://www.linkedin.com/in/mares-popa/" class="text-[#888] hover:text-[#007aff] transition-colors">LinkedIn</a>
            <a href="https://www.github.com/marespopa" class="text-[#888] hover:text-[#007aff] transition-colors">GitHub</a>
          </div>
        </section>
      </main>

      <footer class="mt-32 opacity-30 text-[11px]">
        <p>Sorted {new Date().getFullYear()}</p>
      </footer>
    </div>

  </body>
</html>
