---
import { getCollection, render } from 'astro:content';
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} — Mares Popa</title>
    <GoogleAnalytics measurementId={"G-WY0KQ8W98H"} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    
    <script is:inline>
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>

  <body class="bg-[#f8f8f8] dark:bg-[#1a1a1a] text-[#111] dark:text-[#eee] font-mono selection:bg-[#007aff]/20 transition-colors duration-500 antialiased">
    
    <div class="max-w-[640px] mx-auto px-10 py-24 md:py-44">
      
      <header class="flex justify-between items-baseline mb-24">
        <a href="/" class="text-[14px] font-bold tracking-tight hover:text-[#007aff] transition-colors">Mares Popa</a>
        <ThemeToggle />
      </header>

      <article>
        <header class="mb-16 space-y-4">
          <h1 class="text-[24px] md:text-[28px] font-bold leading-[1.3] tracking-tighter text-balance">
            {post.data.title}
          </h1>
          <div class="flex items-center gap-4 text-[12px] text-[#bbb] dark:text-[#444] tabular-nums">
            <time>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
            </time>
            <span class="w-1 h-1 bg-[#007aff] rounded-full"></span>
            <span class="uppercase tracking-widest">Post</span>
          </div>
        </header>

        <main class="
          text-[16px] md:text-[17px] leading-[1.8] tracking-normal
          prose-custom
          prose-headings:text-[#111] dark:prose-headings:text-[#eee]
          prose-headings:font-bold prose-headings:tracking-tighter
          prose-p:mb-8
          prose-a:text-[#007aff] prose-a:no-underline hover:prose-a:underline
          prose-strong:font-bold
          prose-code:text-[#007aff] prose-code:bg-[#007aff]/5 prose-code:px-1 prose-code:rounded
          prose-img:rounded-sm
        ">
          <Content />
        </main>

        <footer class="mt-32 pt-12 border-t border-[#eee] dark:border-[#262626]">
          <a href="/blog" class="text-[13px] text-[#999] hover:text-[#007aff] transition-colors">
            ← Return to Index
          </a>
        </footer>
      </article>

      <footer class="mt-40 text-[#ccc] dark:text-[#333] text-[10px] tracking-[0.3em] uppercase">
        <p>© {new Date().getFullYear()} Mares Popa</p>
      </footer>
    </div>

    <style is:global>
      /* Custom iA Writer-style overrides for markdown content */
      .prose-custom h2 { @apply text-[20px] mt-16 mb-4 font-bold; }
      .prose-custom h3 { @apply text-[18px] mt-12 mb-2 font-bold; }
      .prose-custom ul { @apply list-disc list-outside ml-5 mb-8 space-y-2; }
      .prose-custom ol { @apply list-decimal list-outside ml-5 mb-8 space-y-2; }
      .prose-custom blockquote { @apply border-l-2 border-[#007aff] pl-6 italic text-[#888] mb-8; }
      .prose-custom hr { @apply border-[#eee] dark:border-[#262626] my-16; }
    </style>
  </body>
</html>
