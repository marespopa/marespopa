---
import { getCollection } from 'astro:content';
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

// Fetch all posts and sort them by date
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Writing — Mares Popa</title>
    <GoogleAnalytics measurementId={"G-WY0KQ8W98H"} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    
    <script is:inline>
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>

  <body class="bg-[#f8f8f8] dark:bg-[#1a1a1a] text-[#111] dark:text-[#eee] font-mono selection:bg-[#007aff]/20 transition-colors duration-500 antialiased">
    
    <div class="max-w-[640px] mx-auto px-10 py-24 md:py-44">
      
      <header class="flex justify-between items-baseline mb-32">
        <a href="/" class="text-[14px] font-bold tracking-tight hover:text-[#007aff] transition-colors">Mares Popa</a>
        <ThemeToggle />
      </header>

      <main>
        <header class="mb-20">
          <h1 class="text-[11px] font-bold text-[#007aff] uppercase tracking-[0.2em] mb-4">Posts</h1>
          <p class="text-[#888] dark:text-[#666] text-sm">A collection of thoughts on the software world.</p>
        </header>

        <section class="space-y-12">
          {posts.map(post => (
            <div class="group">
              <time class="block text-[12px] text-[#bbb] dark:text-[#444] mb-2 tabular-nums">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
              </time>
              <a href={`/blog/${post.id}`} class="text-[18px] font-medium group-hover:text-[#007aff] transition-colors underline decoration-transparent group-hover:decoration-[#007aff]/30 underline-offset-4">
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="text-[#888] dark:text-[#666] text-[14px] mt-2 leading-relaxed max-w-md">
                  {post.data.description}
                </p>
              )}
            </div>
          ))}
        </section>

        <footer class="mt-32 pt-12 border-t border-[#eee] dark:border-[#262626]">
          <a href="/" class="text-[13px] text-[#999] hover:text-[#007aff] transition-colors">
            ← Home
          </a>
        </footer>
      </main>

      <footer class="mt-40 text-[#ccc] dark:text-[#333] text-[10px] tracking-[0.3em] uppercase">
        <p>© {new Date().getFullYear()} Mares Popa</p>
      </footer>
    </div>

  </body>
</html>
